{
  "name": "among-demons",
  "version": "1.0.1",
  "private": true,
  "description": "Fullscreen desktop app for Among Demons.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.amongdemons.steam",
    "productName": "Among Demons",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "steam-ui.css",
      "assets/icon.ico",
      "assets/icon.png",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Among Demons"
    }
  }
}
